------------------------------------------------------------
-- DEFENSE STATES
------------------------------------------------------------
local DEF = {
    ANTI_RAGDOLL = false,
    NO_KNOCKBACK = false,
    ANTI_SLOW    = false,
    ANTI_VOID    = false,
}
local defConns = {}

local function defDisconnect(key)
    if defConns[key] then defConns[key]:Disconnect(); defConns[key]=nil end
end

local function def_antiRagdoll(on)
    defDisconnect("ragdoll"); if not on then return end
    defConns["ragdoll"] = RunService.Heartbeat:Connect(function()
        if not DEF.ANTI_RAGDOLL then return end
        local char = LocalPlayer.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        local st = hum:GetState()
        if st == Enum.HumanoidStateType.Ragdoll
        or st == Enum.HumanoidStateType.FallingDown
        or st == Enum.HumanoidStateType.Physics then
            pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        end
        if hum.PlatformStand then pcall(function() hum.PlatformStand = false end) end
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("Motor6D") and not v.Enabled then
                pcall(function() v.Enabled = true end)
            end
        end
    end)
end

local function def_noKnockback(on)
    defDisconnect("knockback"); if not on then return end
    defConns["knockback"] = RunService.Heartbeat:Connect(function()
        if not DEF.NO_KNOCKBACK then return end
        local char = LocalPlayer.Character
        local hrp2 = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp2 then return end
        for _, v in ipairs(hrp2:GetChildren()) do
            if v:IsA("BodyVelocity") or v:IsA("BodyForce") or v:IsA("BodyAngularVelocity") then
                pcall(function() v:Destroy() end)
            end
        end
    end)
end

local function def_antiSlow(on)
    defDisconnect("slow"); if not on then return end
    defConns["slow"] = RunService.Heartbeat:Connect(function()
        if not DEF.ANTI_SLOW then return end
        local char = LocalPlayer.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        if hum.WalkSpeed < 13 then pcall(function() hum.WalkSpeed = 16 end) end
        if hum.JumpPower  < 35 then pcall(function() hum.JumpPower  = 50 end) end
    end)
end

local _lastSafe = nil
local function def_antiVoid(on)
    defDisconnect("void"); if not on then return end
    local t2 = 0
    defConns["void"] = RunService.Heartbeat:Connect(function(dt)
        if not DEF.ANTI_VOID then return end
        local hrp2 = getHRP()
        if not hrp2 then return end
        t2 = t2 + dt
        if t2 >= 2 then
            t2 = 0
            if hrp2.Position.Y > -50 then _lastSafe = hrp2.Position + Vector3.new(0,4,0) end
        end
        if hrp2.Position.Y < -100 and _lastSafe then
            pcall(function() hrp2.CFrame = CFrame.new(_lastSafe) end)
        end
    end)
end



------------------------------------------------------------
-- HELPERS
------------------------------------------------------------
local function getHRP()
    local c = LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    local c = LocalPlayer.Character
    return c and c:FindFirstChildOfClass("Humanoid")
end

local function isAlive(char)
    if not char then return false end
    local h = char:FindFirstChildOfClass("Humanoid")
    return h and h.Health > 0
end

local function safeCall(fn, ...)
    local ok, err = pcall(fn, ...)
    if not ok then
        -- silently fail — Delta doesn't crash on pcall errors
    end
    return ok
end

-- Find a remote anywhere in game by keyword
local function findRemote(keywords)
    local searchRoots = {ReplicatedStorage}
    pcall(function() table.insert(searchRoots, LocalPlayer.PlayerGui) end)
    for _, root in ipairs(searchRoots) do
        for _, v in pairs(root:GetDescendants()) do
            if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
                local lower = v.Name:lower()
                for _, kw in ipairs(keywords) do
                    if lower:find(kw:lower()) then return v end
                end
            end
        end
    end
    return nil
end

local function fireRemote(remote, ...)
    if not remote then return end
    safeCall(function(...)
        if remote:IsA("RemoteEvent") then
            remote:FireServer(...)
        elseif remote:IsA("RemoteFunction") then
            remote:InvokeServer(...)
        end
    end, ...)
end

