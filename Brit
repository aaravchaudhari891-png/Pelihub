--   AUTO-FARM
-- ════════════════════════════════
------------------------------------------------------------
local afRunning = false
local afThread  = nil

local FARM_TARGETS = {
    Collect = {"CollectPart","Resource","Item","Pickup","Drop","Collectible","Coin","Gem","Crystal","Chest"},
    Trade   = {"TradingNPC","Trader","ShopNPC","Vendor","NPC","TradePart"},
    Reward  = {"RewardPart","DailyReward","Reward","Bonus","ClaimPart","Daily","Claim"},
}

local FARM_REMOTES = {
    Collect = {"collect","collectitem","claim","pickup","gather","item"},
    Trade   = {"trade","traderequest","offer","exchange"},
    Reward  = {"reward","claimreward","daily","bonus","claim"},
}

local function af_delay()
    local base = S.AF_DELAY
    if S.AF_RAND then return base + (math.random() * 0.8 - 0.4) end
    return base
end

local function af_findTargets()
    local keywords = FARM_TARGETS[S.AF_MODE] or {}
    local found = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj and obj.Parent then
            local name = obj.Name:lower()
            for _, kw in ipairs(keywords) do
                if name:find(kw:lower()) then
                    local pos
                    if obj:IsA("BasePart") then
                        pos = obj.Position
                    elseif obj:IsA("Model") then
                        safeCall(function() pos = obj:GetPivot().Position end)
                    end
                    if pos then
                        table.insert(found, {obj=obj, pos=pos})
                        break
                    end
                end
            end
        end
    end
    return found
end

local function af_teleport(pos)
    local myHRP = getHRP(); if not myHRP then return end
    if S.TP_ANTIKICK then
        -- Hop in steps to avoid position-sanity anti-cheat
        local startPos = myHRP.Position
        local dist = (pos - startPos).Magnitude
        local steps = math.clamp(math.ceil(dist / 45), 1, 8)
        for i = 1, steps do
            local t = i / steps
            local mid = startPos:Lerp(pos + Vector3.new(0, 3, 0), t)
            safeCall(function() myHRP.CFrame = CFrame.new(mid) end)
            task.wait(S.TP_DELAY / steps)
        end
    else
        safeCall(function() myHRP.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0)) end)
        task.wait(0.1)
    end
end

local function af_interact(obj)
    -- Method 1: ProximityPrompt (try game function first, then manual trigger)
    for _, pp in pairs(obj:GetDescendants()) do
        if pp:IsA("ProximityPrompt") then
            -- Standard way — trigger the held event
            safeCall(function()
                local old = pp.HoldDuration
                pp.HoldDuration = 0
                pp.MaxActivationDistance = 60
                -- Fire the internal triggered signal
                pp.Triggered:Fire(LocalPlayer)
                task.wait(0.05)
                pp.HoldDuration = old
            end)
            return true
        end
    end
    -- Method 2: ClickDetector
    for _, cd in pairs(obj:GetDescendants()) do
        if cd:IsA("ClickDetector") then
            safeCall(function()
                local fakeMouse = LocalPlayer:GetMouse()
                cd:FireClick(LocalPlayer)
            end)
            return true
        end
    end
    return false
end

local function af_loop()
    while afRunning do
        local targets = af_findTargets()
        local remote  = findRemote(FARM_REMOTES[S.AF_MODE] or {})

        if #targets == 0 then
            task.wait(2)
        else
            for _, t in ipairs(targets) do
                if not afRunning then break end

                if S.AF_TP then af_teleport(t.pos) end
                task.wait(af_delay())

                -- Try interact then remote
                local interacted = af_interact(t.obj)
                if not interacted and remote then
                    -- Fire with object ref, then bare
                    fireRemote(remote, t.obj)
                    task.wait(0.2 + math.random() * 0.3)
                    fireRemote(remote)
                end

                task.wait(af_delay())
            end
        end
        task.wait(0.5)
    end
end

local function af_start()
    if afRunning then return end
    afRunning = true
    afThread  = task.spawn(af_loop)
end

local function af_stop()
    afRunning = false
    if afThread then
        afThread = nil  -- thread will exit via afRunning=false
        afThread = nil
    end
end

