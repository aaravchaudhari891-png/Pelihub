    local count = 0
    local roots = {ReplicatedStorage, workspace}
    safeCall(function() table.insert(roots, LocalPlayer.PlayerGui) end)
    for _, root in ipairs(roots) do
        for _, v in pairs(root:GetDescendants()) do
