-- ════════════════════════════════
--   SILENT AIM
--   Delta-safe: wraps the specific remote's InvokeServer
--   directly on the object — no metamethod hooks needed.
-- ════════════════════════════════
------------------------------------------------------------
local saActive      = false
local saOrigInvoke  = nil
local saRemote      = nil
local saFOVGui      = nil
local saFOVFrame    = nil
local saFOVConn     = nil

local function sa_getTarget()
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local camPos = Camera.CFrame.Position
    local myHRP  = getHRP()
    local best, bestVal = nil, math.huge

    for _, v in pairs(Players:GetPlayers()) do
        local skip = false
        if v == LocalPlayer then skip = true end
        if not skip and S.SA_TEAM and v.Team and LocalPlayer.Team and v.Team == LocalPlayer.Team then skip = true end
        local char = v.Character
        if not char then skip = true end
        if not skip and not isAlive(char) then skip = true end
        if not skip then
            -- Pick aim part
            local part
            if S.SA_PART == "Head" then
                part = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
            elseif S.SA_PART == "Torso" then
                part = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso") or char:FindFirstChild("HumanoidRootPart")
            else
                local bDist, bPart = math.huge, nil
                for _, pn in ipairs({"Head","UpperTorso","HumanoidRootPart"}) do
                    local p = char:FindFirstChild(pn)
                    if p then
                        local sp2, on2 = Camera:WorldToViewportPoint(p.Position)
                        if on2 then
                            local d = (Vector2.new(sp2.X,sp2.Y)-center).Magnitude
                            if d < bDist then bDist=d; bPart=p end
                        end
                    end
                end
                part = bPart
            end
            if not part or not part.Parent then skip = true end
            if not skip then
                local ok, sp = pcall(function() return Camera:WorldToViewportPoint(part.Position) end)
                if not ok or sp.Z <= 0 then skip = true end
                if not skip then
                    local screenDist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                    if screenDist > S.SA_FOV then skip = true end
                    if not skip and S.SA_VIS then
                        local rp = RaycastParams.new()
                        rp.FilterType = Enum.RaycastFilterType.Exclude
                        rp.FilterDescendantsInstances = {char, character}
                        local hit = workspace:Raycast(camPos, part.Position - camPos, rp)
                        if hit then skip = true end
                    end
                    if not skip then
                        local metric
                        if S.SA_PRIORITY == "Crosshair" then
                            metric = screenDist
                        elseif S.SA_PRIORITY == "Distance" then
                            metric = myHRP and (part.Position - myHRP.Position).Magnitude or screenDist
                        elseif S.SA_PRIORITY == "Health" then
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            metric = hum and hum.Health or 100
                        else
                            metric = screenDist
                        end
                        if metric < bestVal then bestVal = metric; best = part end
                    end
                end
            end
        end
    end
    return best
end

-- FOV circle using ScreenGui (no Drawing API needed)
local function sa_buildFOVGui()
    if saFOVGui then saFOVGui:Destroy(); saFOVGui=nil; saFOVFrame=nil end
    local sg = Instance.new("ScreenGui")
    sg.Name = "ShadowSAFOV"; sg.ResetOnSpawn = false
    sg.IgnoreGuiInset = true; sg.DisplayOrder = 50
    safeCall(function() sg.Parent = game:GetService("CoreGui") end)
    if not sg.Parent then sg.Parent = LocalPlayer:WaitForChild("PlayerGui") end

    local f = Instance.new("Frame", sg)
    local d = S.SA_FOV * 2
    f.Size = UDim2.new(0, d, 0, d)
    f.Position = UDim2.new(0.5, 0, 0.5, 0)
    f.AnchorPoint = Vector2.new(0.5, 0.5)
    f.BackgroundTransparency = 1; f.BorderSizePixel = 0
    Instance.new("UICorner", f).CornerRadius = UDim.new(1, 0)
    local stroke = Instance.new("UIStroke", f)
    stroke.Color = Color3.fromRGB(255, 255, 255); stroke.Thickness = 1.5; stroke.Transparency = 0.2
    saFOVGui = sg; saFOVFrame = f; saFOVFrame._stroke = stroke
end

local function sa_updateFOVColor(locked)
    if saFOVFrame and saFOVFrame._stroke then
        saFOVFrame._stroke.Color = locked
            and Color3.fromRGB(255, 50, 50)
            or  Color3.fromRGB(255, 255, 255)
    end
end

-- Hook: wrap InvokeServer on the remote object directly
-- This is the only method that works on Delta/Fluxus/Hydrogen
local function sa_hookRemote(remote)
    if not remote then return false end
    local ok, origFn = pcall(function() return remote.InvokeServer end)
    if not ok or type(origFn) ~= "function" then return false end

    saOrigInvoke = origFn
    saRemote     = remote

    safeCall(function()
        remote.InvokeServer = function(self, ...)
            if S.SA_ON then
                local target = sa_getTarget()
                if target then
                    local oldCF = Camera.CFrame
                    Camera.CFrame = CFrame.new(oldCF.Position, target.Position)
                    local r = saOrigInvoke(self, ...)
                    Camera.CFrame = oldCF
                    return r
                end
            end
            return saOrigInvoke(self, ...)
        end
    end)
    return true
end

-- Also wrap FireServer for RemoteEvent remotes
local function sa_hookRemoteEvent(remote)
    if not remote then return false end
    local ok, origFn = pcall(function() return remote.FireServer end)
    if not ok or type(origFn) ~= "function" then return false end

    saOrigInvoke = origFn
    saRemote     = remote

    safeCall(function()
        remote.FireServer = function(self, ...)
            if S.SA_ON then
                local target = sa_getTarget()
                if target then
                    local oldCF = Camera.CFrame
                    Camera.CFrame = CFrame.new(oldCF.Position, target.Position)
                    local r = saOrigInvoke(self, ...)
                    Camera.CFrame = oldCF
                    return r
                end
            end
            return saOrigInvoke(self, ...)
        end
    end)
    return true
end

local function sa_start()
    if saActive then return end
    saActive = true
    sa_buildFOVGui()

    -- Try to find and hook the attack remote
    -- Search for any shoot/attack/bullet remote in ReplicatedStorage
    local ATTACK_KEYWORDS = {"shoot","attack","bullet","fire","weapon","damage","hit","projectile","gun"}
    local hooked = false
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if not hooked and (v:IsA("RemoteFunction") or v:IsA("RemoteEvent")) then
            local lower = v.Name:lower()
            for _, kw in ipairs(ATTACK_KEYWORDS) do
                if lower:find(kw) then
                    if v:IsA("RemoteFunction") then hooked = sa_hookRemote(v)
                    else hooked = sa_hookRemoteEvent(v) end
                    if hooked then break end
                end
            end
        end
        if hooked then break end
    end

    -- FOV color update loop
    cleanConn("sa_fov")
    Conns["sa_fov"] = RunService.RenderStepped:Connect(function()
        if not S.SA_ON then cleanConn("sa_fov"); return end
        sa_updateFOVColor(sa_getTarget() ~= nil)
        -- Keep FOV circle centered (viewport can resize)
        if saFOVFrame then
            local d = S.SA_FOV * 2
            saFOVFrame.Size = UDim2.new(0, d, 0, d)
        end
    end)
end

local function sa_stop()
    S.SA_ON  = false
    saActive = false
    cleanConn("sa_fov")
    if saFOVGui then saFOVGui:Destroy(); saFOVGui=nil; saFOVFrame=nil end
    -- Restore original function if possible
    if saRemote and saOrigInvoke then
        safeCall(function()
            if saRemote:IsA("RemoteFunction") then
                saRemote.InvokeServer = saOrigInvoke
            else
                saRemote.FireServer = saOrigInvoke
            end
        end)
        saRemote = nil; saOrigInvoke = nil
    end
end

