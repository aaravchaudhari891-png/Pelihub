    end
end

function updateSpeedDisplay()
    speedValueLabel.Text = string.format("%.1fs", TELEPORT_SPEED)
    -- Update slider position (0.05 to 0.5 range mapped to 0-1)
    local sliderPos = (TELEPORT_SPEED - 0.05) / 0.45
    sliderButton.Position = UDim2.new(sliderPos, -7.5, 0, -5)
end

function getRandomPosition()
    local currentPos = humanoidRootPart.Position
    local randomX = currentPos.X + math.random(-TELEPORT_RANGE, TELEPORT_RANGE)
    local randomZ = currentPos.Z + math.random(-TELEPORT_RANGE, TELEPORT_RANGE)
    local randomY = currentPos.Y
    
    return Vector3.new(randomX, randomY, randomZ)
end

function findDeadEnemy()
    for _, otherPlayer in ipairs(game:GetService("Players"):GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character then
            local humanoid = otherPlayer.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health <= 0 then
                local root = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    return root
                end
            end
        end
    end
    return nil
end

-- Fast teleport loop
function startTeleportLoop()
    if teleporting then return end
    teleporting = true
    
    -- Create visual effect for active state
    local loopEffect = Instance.new("Part")
    loopEffect.Size = Vector3.new(3, 3, 3)
    loopEffect.Position = humanoidRootPart.Position
    loopEffect.Anchored = true
    loopEffect.CanCollide = false
    loopEffect.Material = Enum.Material.Neon
    loopEffect.BrickColor = BrickColor.new("Bright violet")
    loopEffect.Parent = workspace
    
    -- Fade in/out effect
    spawn(function()
        while teleporting and loopEffect do
            tweenService:Create(loopEffect, TweenInfo.new(0.5), {Transparency = 0.3}):Play()
            wait(0.5)
            tweenService:Create(loopEffect, TweenInfo.new(0.5), {Transparency = 0.7}):Play()
            wait(0.5)
        end
    end)
    
    -- Fast teleport loop
    while teleporting and LOOP_ENABLED do
        -- Quick random teleport
        local randomPos = getRandomPosition()
        humanoidRootPart.CFrame = CFrame.new(randomPos)
        
        -- Quick void effect
        local voidEffect = Instance.new("Part")
        voidEffect.Size = Vector3.new(2, 2, 2)
        voidEffect.Position = randomPos
        voidEffect.Anchored = true
        voidEffect.CanCollide = false
        voidEffect.Material = Enum.Material.Neon
        voidEffect.BrickColor = BrickColor.new("Bright violet")
        voidEffect.Parent = workspace
        
        -- Fast fade
        tweenService:Create(voidEffect, TweenInfo.new(TELEPORT_SPEED), {Transparency = 1}):Play()
        debris:AddItem(voidEffect, TELEPORT_SPEED)
        
        wait(TELEPORT_SPEED / 2) -- Half speed for next teleport
        
        -- Find and teleport to dead enemy
        local enemyRoot = findDeadEnemy()
        if enemyRoot then
            humanoidRootPart.CFrame = enemyRoot.CFrame + Vector3.new(0, 3, 0)
            
            -- Quick enemy effect
            local enemyEffect = Instance.new("Part")
            enemyEffect.Size = Vector3.new(3, 3, 3)
            enemyEffect.Position = enemyRoot.Position
            enemyEffect.Anchored = true
            enemyEffect.CanCollide = false
            enemyEffect.Material = Enum.Material.Neon
            enemyEffect.BrickColor = BrickColor.new("Bright red")
            enemyEffect.Parent = workspace
            
            tweenService:Create(enemyEffect, TweenInfo.new(TELEPORT_SPEED), {Transparency = 1, Size = Vector3.new(8, 8, 8)}):Play()
            debris:AddItem(enemyEffect, TELEPORT_SPEED)
        end
        
        wait(TELEPORT_SPEED / 2)
        
        -- Update loop effect position
        if loopEffect then
            loopEffect.Position = humanoidRootPart.Position
        end
    end
    
    -- Cleanup
    if loopEffect then
        loopEffect:Destroy()
    end
    teleporting = false
end

function stopTeleportLoop()
    LOOP_ENABLED = false
    teleporting = false
    updateUI()
end

-- Slider drag functionality
local dragging = false
sliderButton.MouseButton1Down:Connect(function()
    dragging = true
end)

userInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

userInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local mousePos = userInputService:GetMouseLocation()
        local sliderPos = mainFrame.AbsolutePosition.X + sliderBar.AbsolutePosition.X
        local relativeX = math.clamp(mousePos.X - sliderPos, 0, sliderBar.AbsoluteSize.X)
        local percent = relativeX / sliderBar.AbsoluteSize.X
        
        -- Map 0-1 to 0.05-0.5
        TELEPORT_SPEED = 0.05 + (percent * 0.45)
        updateSpeedDisplay()
    end
end)

