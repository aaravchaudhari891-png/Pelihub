-- ════════════════════════════════
--   ESP  — BillboardGui based
--   Works on ALL executors (no Drawing API)
-- ════════════════════════════════
------------------------------------------------------------
local espBillboards = {}  -- [player] = billboardGui

local function esp_hpColor(pct)
    if pct > 0.6 then return Color3.fromRGB(0, 220, 80)
    elseif pct > 0.3 then return Color3.fromRGB(255, 200, 0)
    else return Color3.fromRGB(255, 50, 50) end
end

local function esp_playerColor(player)
    if player.Team and S.ESP_NAMES then
        local tc = player.TeamColor
        return Color3.fromRGB(tc.r*255, tc.g*255, tc.b*255)
    end
    return Color3.fromRGB(255, 80, 100)
end

local function esp_create(player)
    if espBillboards[player] then return end
    local char = player.Character; if not char then return end
    local head = char:FindFirstChild("Head"); if not head then return end

    local bb = Instance.new("BillboardGui")
    bb.Name          = "ShadowESP_"..player.Name
    bb.Adornee       = head
    bb.Size          = UDim2.new(0, 120, 0, 60)
    bb.StudsOffset   = Vector3.new(0, 2.5, 0)
    bb.AlwaysOnTop   = true
    bb.MaxDistance   = S.ESP_MAX_DIST
    bb.ResetOnSpawn  = false
    bb.Parent        = head

    local frame = Instance.new("Frame", bb)
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 1
    frame.BorderSizePixel = 0

    local layout = Instance.new("UIListLayout", frame)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.Padding = UDim.new(0, 1)

    -- NAME
    local nameLabel = Instance.new("TextLabel", frame)
    nameLabel.Name = "NameTag"
    nameLabel.Size = UDim2.new(1, 0, 0, 18)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.DisplayName
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 13
    nameLabel.TextColor3 = esp_playerColor(player)
    nameLabel.TextStrokeTransparency = 0.5
    nameLabel.TextStrokeColor3 = Color3.new(0,0,0)
    nameLabel.Visible = S.ESP_NAMES
    nameLabel.LayoutOrder = 1

    -- DISTANCE
    local distLabel = Instance.new("TextLabel", frame)
    distLabel.Name = "DistTag"
    distLabel.Size = UDim2.new(1, 0, 0, 14)
    distLabel.BackgroundTransparency = 1
    distLabel.Text = ""
    distLabel.Font = Enum.Font.Gotham
    distLabel.TextSize = 11
    distLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    distLabel.TextStrokeTransparency = 0.4
    distLabel.TextStrokeColor3 = Color3.new(0,0,0)
    distLabel.Visible = S.ESP_DIST
    distLabel.LayoutOrder = 2

    -- HP BAR BACKGROUND
    local hpBG = Instance.new("Frame", frame)
    hpBG.Name = "HPBG"
    hpBG.Size = UDim2.new(0.85, 0, 0, 7)
    hpBG.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    hpBG.BorderSizePixel = 0
    hpBG.Visible = S.ESP_HP
    hpBG.LayoutOrder = 3
    Instance.new("UICorner", hpBG).CornerRadius = UDim.new(1, 0)

    local hpFill = Instance.new("Frame", hpBG)
    hpFill.Name = "HPFill"
    hpFill.Size = UDim2.new(1, 0, 1, 0)
    hpFill.BackgroundColor3 = Color3.fromRGB(0, 220, 80)
    hpFill.BorderSizePixel = 0
    Instance.new("UICorner", hpFill).CornerRadius = UDim.new(1, 0)

    espBillboards[player] = {
        bb      = bb,
        name    = nameLabel,
        dist    = distLabel,
        hpBG    = hpBG,
        hpFill  = hpFill,
        frame   = frame,
    }
end

local function esp_remove(player)
    local obj = espBillboards[player]
    if obj then
        safeCall(function() obj.bb:Destroy() end)
        espBillboards[player] = nil
    end
end

local function esp_update(player)
    local obj = espBillboards[player]; if not obj then return end
    local char = player.Character

    if not char or not isAlive(char) then
        obj.bb.Enabled = false; return
    end

    local myHRP = getHRP()
    local pHRP  = char:FindFirstChild("HumanoidRootPart")
    if not pHRP then obj.bb.Enabled = false; return end

    local dist = myHRP and (pHRP.Position - myHRP.Position).Magnitude or 0
    if dist > S.ESP_MAX_DIST then obj.bb.Enabled = false; return end

    obj.bb.Enabled = true

    -- Update adornee in case character respawned
    local head = char:FindFirstChild("Head")
    if head and obj.bb.Adornee ~= head then obj.bb.Adornee = head end

    -- NAME
    obj.name.Visible = S.ESP_NAMES
    obj.name.Text    = player.DisplayName

    -- DIST
    obj.dist.Visible = S.ESP_DIST
    obj.dist.Text    = string.format("[%d st]", math.floor(dist))

    -- HP
    obj.hpBG.Visible = S.ESP_HP
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        local pct = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
        obj.hpFill.Size             = UDim2.new(pct, 0, 1, 0)
        obj.hpFill.BackgroundColor3 = esp_hpColor(pct)
    end
end

local function esp_start()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer then esp_create(v) end
    end
    Players.PlayerAdded:Connect(function(v)
        if S.ESP_ON then task.wait(1); esp_create(v) end
    end)
    Players.PlayerRemoving:Connect(function(v) esp_remove(v) end)
    LocalPlayer.CharacterAdded:Connect(function()
        -- Re-add ESP for all players after our own respawn
        task.wait(1)
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer then
                esp_remove(v); if S.ESP_ON then esp_create(v) end
            end
        end
    end)

    cleanConn("esp")
    Conns["esp"] = RunService.Heartbeat:Connect(function()
        if not S.ESP_ON then
            for _, v in pairs(Players:GetPlayers()) do
                local obj = espBillboards[v]
                if obj then obj.bb.Enabled = false end
            end
            cleanConn("esp"); return
        end
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer then
                if not espBillboards[v] then esp_create(v) end
                esp_update(v)
            end
        end
    end)
end

local function esp_stop()
    cleanConn("esp")
    for _, v in pairs(Players:GetPlayers()) do
        local obj = espBillboards[v]
        if obj then obj.bb.Enabled = false end
    end
end

